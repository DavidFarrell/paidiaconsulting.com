{
	admin off
	auto_https off
}

:{$PORT:3000} {
	root * /app
	encode zstd gzip

	# Assets aren't content-hashed, so avoid "immutable" (it would pin an
	# overwritten file for a year). Cache an hour for speed, then serve-stale
	# while revalidating - so an in-place asset edit propagates within ~a day
	# on its own, and a query bump (?v=N) forces it immediately.
	@static {
		path *.css *.js *.woff2 *.woff *.png *.webp *.svg *.ico *.jpg *.jpeg
	}
	header @static Cache-Control "public, max-age=3600, stale-while-revalidate=86400"

	# HTML revalidates quickly so content edits go live without a hard refresh.
	@html {
		path *.html /
	}
	header @html Cache-Control "public, max-age=300, must-revalidate"

	# Presentations area: reachable only by link, never indexed.
	header /presentations/* X-Robots-Tag "noindex, nofollow"

	# GOSH client decks sit behind basic auth (user: david). One login per
	# browser session covers both decks.
	@goshDecks path /presentations/gosh/*
	basic_auth @goshDecks {
		david $2a$14$tlzDr7TxxWCc9ljqoS5LAuTJF36u9z8TbdnSHJEo0fGLj6AQcst1G
	}

	# Infrastructure files aren't content - don't serve them.
	@infra path /server/* /start.sh /Caddyfile /railpack.json /nixpacks.toml
	respond @infra 404

	# Private file transfer box: drag-drop UI at /files/, API proxied to the
	# local Node file server. Same password as the GOSH decks (user: david).
	header /files/* X-Robots-Tag "noindex, nofollow"
	@filesArea path /files /files/*
	basic_auth @filesArea {
		david $2a$14$tlzDr7TxxWCc9ljqoS5LAuTJF36u9z8TbdnSHJEo0fGLj6AQcst1G
	}
	reverse_proxy /files/api/* 127.0.0.1:8484

	# presentations.paidiaconsulting.com lands on the presentations index.
	# Deep paths already resolve on any host, so only bare / needs the redirect.
	@presRoot {
		host presentations.paidiaconsulting.com
		path /
	}
	redir @presRoot /presentations/ 302

	file_server
}
