{
	admin off
	auto_https off
}

:{$PORT:3000} {
	root * /app
	encode zstd gzip

	# Long-lived caching for fingerprinted/static assets. These filenames are
	# stable, so a year + immutable is safe; bump a filename to bust the cache.
	@static {
		path *.css *.js *.woff2 *.woff *.png *.webp *.svg *.ico *.jpg *.jpeg
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# HTML revalidates quickly so content edits go live without a hard refresh.
	@html {
		path *.html /
	}
	header @html Cache-Control "public, max-age=300, must-revalidate"

	file_server
}
